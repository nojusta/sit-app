APPWRITE_PROJECT_NAME="sit"

# Public Appwrite API endpoint, usually https://<region>.cloud.appwrite.io/v1
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1

# Appwrite project ID from Project settings -> General
APPWRITE_PROJECT_ID=

# Storage bucket ID used for profile picture uploads
APPWRITE_STORAGE_ID=


#TODO: Legacy values kept because app.config.js still exports them; currently unused in app runtime
APPWRITE_DATABASE_ID=
APPWRITE_USER_COLLECTION_ID=
APPWRITE_MARKERS_COLLECTION_ID=

# Optional dev-only credentials for the "Dev Log" button on the landing screen
ADMIN_EMAIL=
ADMIN_PASSWORD=
